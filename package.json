{
  "name": "nest-typescript-starter",
  "private": true,
  "version": "1.0.0",
  "description": "Nest TypeScript starter repository",
  "license": "MIT",
  "scripts": {
    "prebuild": "rimraf dist",
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "start": "nest start --watch",
    "start:dev": "nest start --watch",
    "start:debug": "nest start --debug --watch",
    "start:prod": "node dist/main",
    "migrate:create": "ts-node ./node_modules/typeorm/cli.js migration:create ./src/migrations",
    "migrate:generate": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:generate src/migrations/migrations -d ./src/ormconfig.ts",
    "migrate:up": "ts-node -r tsconfig-paths/register ./src/ormup.ts migration:run  -d ./src/ormconfig.ts",
    "migrate:docker:up": "ts-node ./node_modules/typeorm/cli.js migration:run -c docker",
    "migrate:down": "ts-node -r tsconfig-paths/register ./node_modules/typeorm/cli.js migration:revert  -d ./src/ormconfig.ts",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "lint-staged": "lint-staged",
    "lint-staged:js": "eslint --ext .js,.jsx,.ts,.tsx ",
    "prepare": "husky install",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json"
  },
  "dependencies": {
    "@dataui/crud": "^5.3.1",
    "@dataui/crud-typeorm": "^5.3.1",
    "@google-cloud/storage": "^7.9.0",
    "@nestjs-modules/mailer": "^2.0.2",
    "@nestjs/axios": "^4.0.0",
    "@nestjs/bull": "^0.5.4",
    "@nestjs/common": "^8.1.1",
    "@nestjs/config": "^2.0.0",
    "@nestjs/core": "^8.1.1",
    "@nestjs/jwt": "^8.0.0",
    "@nestjs/passport": "^8.2.1",
    "@nestjs/platform-express": "^9.4.0",
    "@nestjs/platform-socket.io": "^11.0.12",
    "@nestjs/schedule": "^2.2.1",
    "@nestjs/swagger": "^5.2.1",
    "@nestjs/typeorm": "^8.0.3",
    "@nestjs/websockets": "8.0.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supercharge/request-ip": "^1.2.0",
    "axios": "^0.27.2",
    "bcrypt": "^5.0.1",
    "body-parse": "^0.1.0",
    "body-parser": "^1.20.0",
    "bull": "^4.8.2",
    "cache-manager": "^3.6.0",
    "cache-manager-redis-store": "^2.0.0",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.13.2",
    "crypto-js": "^4.1.1",
    "date-fns": "^4.1.0",
    "discord.js": "14.11.0",
    "docx-merger": "^1.2.2",
    "docxtemplater": "^3.29.4",
    "dotenv": "^16.0.0",
    "exceljs": "^4.3.0",
    "flat": "^5.0.2",
    "form-data": "^4.0.0",
    "handlebars": "^4.7.8",
    "libreoffice-convert": "^1.4.1",
    "md5": "^2.3.0",
    "moment": "^2.29.3",
    "moment-timezone": "^0.5.40",
    "nest-access-control": "^2.2.0",
    "nodemailer": "^6.9.16",
    "passport": "^0.5.2",
    "passport-jwt": "^4.0.0",
    "pdf-merger-js": "^3.4.0",
    "pg": "^8.13.3",
    "pizzip": "^3.1.1",
    "puppeteer": "^22.9.0",
    "redis": "^4.7.0",
    "reflect-metadata": "^0.1.13",
    "rimraf": "^3.0.2",
    "rxjs": "^7.4.0",
    "socket.io": "^4.8.1",
    "swagger-ui-express": "^4.3.0",
    "typeorm": "0.3",
    "uuid": "^11.1.0",
    "web-streams-polyfill": "^4.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@nestjs/cli": "^8.1.3",
    "@nestjs/schematics": "^8.0.4",
    "@nestjs/testing": "^8.1.1",
    "@types/bull": "^3.15.8",
    "@types/cron": "^2.0.1",
    "@types/express": "^4.17.13",
    "@types/jest": "^27.0.2",
    "@types/multer": "^1.4.7",
    "@types/node": "^22.15.3",
    "@types/passport-jwt": "^3.0.6",
    "@types/pg": "^8",
    "@types/supertest": "^2.0.11",
    "@typescript-eslint/eslint-plugin": "^4.29.2",
    "@typescript-eslint/parser": "^4.29.2",
    "eslint": "^7.32.0",
    "eslint-config-prettier": "^8.3.0",
    "eslint-plugin-prettier": "^3.4.1",
    "husky": "^8.0.3",
    "jest": "^27.3.0",
    "lint-staged": "^15.1.0",
    "prettier": "^2.4.1",
    "source-map-support": "^0.5.20",
    "supertest": "^6.1.6",
    "ts-jest": "^27.0.7",
    "ts-loader": "^9.2.6",
    "ts-node": "^10.3.0",
    "tsconfig-paths": "^3.11.0",
    "typescript": "^4.4.4",
    "validate-commit-msg": "^2.14.0"
  },
  "lint-staged": {
    "**/*.{jsx,ts,tsx}": "yarn lint",
    "**/*.{jsx,tsx,ts,less,md,json}": [
      "yarn format"
    ]
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
